#!/sbin/openrc-run

name="gadget-ha-rclone"
description="USB Gadget Home Assistant + Rclone Sync"

command="/usr/bin/gadget-ha-rclone"
command_background="yes"
pidfile="/run/${name}.pid"
output_logger="logger -t ${name} -p daemon.info"
error_logger="logger -t ${name} -p daemon.err"

# Environmental Defaults
export MQTT_BROKER="@MQTT_BROKER@"
export MQTT_BASE_TOPIC="@MQTT_BASE_TOPIC@"
export RCLONE_PREFIX="@RCLONE_PREFIX@"

depend() {
    need net localmount
    after usb-gadget
}
