#!/sbin/openrc-run

name="gadget-web"
description="USB Gadget Web Portal"

command="/usr/bin/gadget-web"
command_background="yes"
pidfile="/run/${name}.pid"
output_logger="logger -t ${name} -p daemon.info"
error_logger="logger -t ${name} -p daemon.err"

export AP_SSID="@AP_SSID@"

depend() {
    need net localmount
    after usb-gadget
}
